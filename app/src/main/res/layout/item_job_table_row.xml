<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="?attr/colorSurface">

    <!-- 作业名称 -->
    <TextView
        android:id="@+id/tv_job_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="作业名称"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tv_job_time"
        app:layout_constraintWidth_percent="0.45"
        tools:text="示例作业" />

    <!-- 作业时间 -->
    <TextView
        android:id="@+id/tv_job_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="作业时间"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_job_name"
        app:layout_constraintEnd_toStartOf="@id/btn_row_edit"
        app:layout_constraintWidth_percent="0.45"
        android:gravity="end"
        tools:text="2024-01-01 12:00:00" />

    <!-- 编辑按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_row_edit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="编辑"
        android:textSize="12sp"
        android:minWidth="0dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        style="@style/Widget.Material3.Button.TextButton"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_job_time"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"
        android:alpha="0.2"
        app:layout_constraintTop_toBottomOf="@id/tv_job_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>

